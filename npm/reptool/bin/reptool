#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");

const PLATFORMS = {
  "win32-x64": { pkg: "reptool-win32-x64", bin: "reptool.exe" },
  "linux-x64": { pkg: "reptool-linux-x64", bin: "reptool" },
  "darwin-x64": { pkg: "reptool-darwin-x64", bin: "reptool" },
  "darwin-arm64": { pkg: "reptool-darwin-arm64", bin: "reptool" },
};

function getBinaryPath() {
  const platform = `${process.platform}-${process.arch}`;
  const config = PLATFORMS[platform];

  if (!config) {
    console.error(`reptool: 不支持的平台 ${platform}`);
    console.error("支持的平台: win32-x64, linux-x64, darwin-x64, darwin-arm64");
    console.error("请从源码编译: cargo build --release");
    process.exit(1);
  }

  // 尝试从 node_modules 中找到平台包的二进制
  const candidates = [
    // pnpm / npm hoisted
    path.join(__dirname, "..", "..", config.pkg, "bin", config.bin),
    // npm nested node_modules
    path.join(__dirname, "..", "node_modules", config.pkg, "bin", config.bin),
    // global install
    path.join(__dirname, "..", "..", "..", config.pkg, "bin", config.bin),
  ];

  for (const candidate of candidates) {
    if (fs.existsSync(candidate)) {
      return candidate;
    }
  }

  console.error(`reptool: 找不到平台二进制 (${config.pkg})`);
  console.error("请尝试重新安装: npm install -g reptool");
  process.exit(1);
}

const binary = getBinaryPath();

try {
  execFileSync(binary, process.argv.slice(2), {
    stdio: "inherit",
    env: process.env,
  });
} catch (e) {
  if (e.status !== null) {
    process.exit(e.status);
  }
  throw e;
}
